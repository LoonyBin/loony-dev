# loony-dev configuration example
#
# Copy this file to one of the following locations (highest priority wins):
#   ./.loony-dev.toml                          (repo-level / per-checkout)
#   ~/.config/loony-dev/config.toml            (user-level, Linux/macOS)
#   ~/Library/Application Support/loony-dev/config.toml  (user-level, macOS)
#   /etc/loony-dev/config.toml                 (system-wide, POSIX only)
#
# Every tier has a machine-local ".local" sibling (e.g. ".loony-dev.local.toml",
# "config.local.toml") merged directly ABOVE its base file. Use it to override
# a tier on one specific machine without editing — and dirtying — the tracked
# file. Because config is deep-merged, a ".local" file need only contain the
# keys it overrides. These files are never checked in; add
# ".loony-dev.local.toml" to your project's .gitignore (the worker also adds it
# to .git/info/exclude automatically).
#
# Configuration is STRICTLY SCOPED: each section applies only to the matching
# sub-command. There are no shared top-level defaults that flow into
# sub-commands; place every key inside the appropriate [section].
#
# Most keys mirror a CLI flag. A few are advanced tuning knobs that are
# file-only (no flag) and read straight from the section here — they are noted
# inline as "No CLI flag". Every documented key IS read by the code, and every
# configurable Tier-1/2 setting the code reads IS documented here; this file is
# the source of truth for what is configurable. (Tier-3 internal constants are
# intentionally not configurable and live only in code — see CLAUDE.md.)
#
# Priority order (highest wins):
#   1. CLI flags
#   2. Environment variables  LOONY_DEV_<COMMAND>_<KEY>
#   3. ./.loony-dev.local.toml                 (machine-local, never checked in)
#   4. ./.loony-dev.toml
#   5. User config dir config.local.toml       (machine-local)
#   6. User config dir config.toml
#   7. /etc/loony-dev/config.local.toml        (machine-local, POSIX only)
#   8. /etc/loony-dev/config.toml
#   9. Built-in CLI defaults


# ---------------------------------------------------------------------------
# [worker] — loony-dev worker
# ---------------------------------------------------------------------------

[worker]

# GitHub repository to watch (owner/repo).  Detected from git remote when unset.
# repo = "my-org/my-repo"

# Polling interval in seconds.
# interval = 60

# Maximum number of tasks this worker runs at once.  Each task runs in its own
# git worktree; GitHub label state prevents two workers from taking the same item.
# max_concurrent_tasks = 3

# Working directory for the agent (must exist).
# work_dir = "."

# Bot username used for watermark detection.  Detected from `gh auth` when unset.
# bot_name = "my-bot[bot]"

# Write DEBUG logs to this file in addition to stderr.
# log_file = "/var/log/loony-dev/worker.log"

# Enable DEBUG-level logging (default is INFO).
# verbose = true

# GitHub usernames always allowed to trigger runs regardless of collaborator
# role. Use the REST-API login form, including the "[bot]" suffix for bot
# accounts. List "coderabbitai[bot]" here to let the worker act on CodeRabbit's
# review comments (CodeRabbit is not a repo collaborator, so it is otherwise
# unauthorized to trigger runs).
# allowed_users = ["coderabbitai[bot]"]

# Minimum GitHub collaborator role required to trigger agent runs.
# Choices: "triage", "write", "admin"
# min_role = "triage"

# Hours after which an in-progress issue or PR is considered stuck and reset.
# stuck_threshold_hours = 12

# CI check names to ignore when detecting failures.
# skip_ci_checks = ["deploy-preview", "license/cla"]

# Seconds to disable a Claude agent after hitting a quota/rate-limit error
# when no reset time can be parsed from the error message.
# quota_fallback_seconds = 1800

# Wall-clock cap (seconds) on a single `claude -p` turn — one phase of an issue
# (plan, implement, fix a review). On overrun the CLI process group is killed and
# the turn returns rc 124. Raise it if turns are being cut off; lower it to fail
# faster. No CLI flag (advanced tuning); set it here under [worker].
# claude_turn_timeout_seconds = 1800

# Seconds a bot lease-holder's heartbeat may stall before another worker may
# reclaim the pipeline (the middle reclaim tier, below the 12h global backstop).
# Must stay strictly greater than claude_turn_timeout_seconds or a slow-but-live
# worker gets falsely reclaimed. No CLI flag; advanced reliability knob.
# heartbeat_stale_after = 3600

# Display name for the orchestrator/supervisor identity in the activity/event
# feed (the "capo" actor). Rarely changed. No CLI flag.
# capo_name = "capo"

# Number of identical consecutive bot failure comments on an item before it is
# marked with the in-error label and excluded from discovery (requires manual
# intervention to resume).
# repeated_failure_threshold = 2

# When DEFERring a PR review comment that flags a pre-existing latent bug,
# allow the worker to open a follow-up tracking issue with `gh issue create`.
# Set to false to require a human to file follow-ups.
# pr_review_allow_create_issues = true


# ---------------------------------------------------------------------------
# [coderabbit] — Coderabbit CLI integration (optional pre-commit review)
# ---------------------------------------------------------------------------

[coderabbit]

# Set to false to disable Coderabbit review even if the binary is installed.
# enabled = true

# Maximum times to run `coderabbit review` and re-invoke Claude to fix issues
# before proceeding to commit.  Set to 0 to skip review entirely.
# max_review_retries = 3

# Maximum times to retry commit+push after a pre-commit or pre-push hook
# rejects the changes.  Each retry runs Claude to fix the hook failures.
# If all retries are exhausted the commit is prefixed with [WIP].
# max_commit_retries = 3


# ---------------------------------------------------------------------------
# [github] — GitHub API client tuning (shared across all commands)
# ---------------------------------------------------------------------------

[github]

# Seconds to cache a user's repository permission level.
# permission_cache_ttl = 600

# Seconds to cache completed check-run results for a given commit SHA.
# check_runs_cache_ttl = 3600

# Maximum number of retries when a gh CLI call hits a rate-limit or
# transient server error (403, 429, "abuse detection", etc.).
# max_retries = 5

# Initial backoff delay in seconds before the first retry.
# Subsequent retries double the delay (exponential backoff).
# initial_backoff = 2.0


# ---------------------------------------------------------------------------
# [supervisor] — loony-dev supervisor
# ---------------------------------------------------------------------------

[supervisor]

# Base directory for repository checkouts and log files.
#   Checkouts: <base_dir>/<owner>/<repo>
#   Logs:      <base_dir>/.logs/<owner>/<repo>/loony-worker.log
# base_dir = "."

# Supervisor health-check interval in seconds.
# interval = 15

# How often (seconds) to re-discover repositories and check out new ones.
# refresh_interval = 1800

# Glob patterns — only supervise repos matching at least one pattern.
# Patterns with "/" are matched against "owner/repo"; others match repo name only.
# include = ["my-org/*", "my-repo"]

# Glob patterns — skip repos matching any of these (applied after include).
# exclude = ["my-org/archived-*"]

# Minimum seconds before restarting a crashed worker (exponential backoff base).
# min_restart_delay = 5.0

# Maximum backoff delay (seconds) when restarting crashed workers.
# max_restart_delay = 300.0

# How many times a crashed `claude rc` remote-control server is relaunched before
# it is left in an errored state (surfaced in the dashboard) instead of restarted
# forever. Workers are unaffected — they restart indefinitely.
# max_restart_retries = 5

# Write supervisor DEBUG logs to this file.
# log_file = "/var/log/loony-dev/supervisor.log"

# Enable DEBUG-level logging (default is INFO).
# verbose = true

# Do not launch a `claude rc` remote-control server per repo.  Set to true in
# environments without Anthropic relay access to avoid restart churn.
# no_remote_control = false

# Also run the read-only web dashboard (loony-dev web) as a managed child
# process. A single instance serves every repo and is restarted with the same
# backoff as workers. Host/port and other tuning come from the [web] section.
# Equivalent to passing --web on the command line.
# web = false

# GitHub usernames whose repository invitations are auto-accepted by the supervisor.
# Repeatable list. Use ["*"] to accept from anyone (not recommended).
# If unset or empty, no invitations are accepted.
# accept_invites_from = ["trusted-user", "another-user"]


# ---------------------------------------------------------------------------
# [web] — loony-dev web (read-only dashboard)
# ---------------------------------------------------------------------------

[web]

# Base directory to scan for worker logs and PID files (same default as supervisor).
# base_dir = "."

# Path to the supervisor log file.
# Defaults to <base_dir>/.logs/supervisor.log when unset.
# supervisor_log = "/var/log/loony-dev/supervisor.log"

# Address to bind the dashboard to. Defaults to loopback.
# WARNING: the dashboard exposes unauthenticated mutating endpoints (write
# skills/commands, kill processes) — only bind a non-loopback/0.0.0.0 address
# on a trusted network.
# host = "127.0.0.1"

# Port for the web dashboard.
# port = 5338

# Default number of log lines returned by the log-tail endpoint.
# tail_lines = 100

# Global Claude config root for the dashboard's skills/commands editor.
# Defaults to ~/.claude when unset.
# claude_home = "~/.claude"

# Seconds a blocked Claude descendant must be alive before it is reported as
# stuck on the dashboard.
# stuck_after = 300

# Seconds between the two CPU/IO samples used to decide a Claude subtree is idle.
# Only sampled when a blocked candidate process exists, so it is paid rarely.
# activity_sample = 0.3

# Seconds to wait after SIGTERM before escalating to SIGKILL when killing a
# stuck process from the dashboard.
# kill_grace = 5.0
